# =============================================
# Melhores do Ano CDL Aracaju — variáveis de ambiente
# Copie este arquivo para .env.local e preencha.
# =============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- SPC Brasil ---
SPC_API_URL=https://api.spcbrasil.com.br/spcconsulta/recurso/consulta/padrao
SPC_API_URL_HOMOLOG=https://treinamento.spcbrasil.com.br/spcconsulta/recurso/consulta/padrao
SPC_USER=
SPC_PASSWORD=
SPC_AMBIENTE=homologacao
SPC_CODIGO_PRODUTO=11
SPC_MOCK=false
SPC_SAMPLE_RATE=0.5

# --- Z-API (WhatsApp) ---
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# --- Cloudflare Turnstile (anti-bot) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Admin (autenticação simples por senha) ---
ADMIN_PASSWORD=
JWT_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=https://cdlaju.com
HASH_SALT=

# --- Instagram Graph API (postar carrosseis no Instagram) ---
# Obter via /tools/access_token. Page Token e' permanente quando derivado
# de um Long-Lived User Token. Veja docs/setup-instagram.md.
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_PAGE_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_FACEBOOK_PAGE_ID=

# --- Operacional: provisionamento DNS automatico (signup self-service) ---
# Se vazio, signup pula provisionamento e admin cuida manualmente do DNS.
#
# Cloudflare: token com scope "Zone:DNS:Edit" + zone id de melhoresdoano.app
#   Pegar em: https://dash.cloudflare.com/profile/api-tokens
#   E em https://dash.cloudflare.com/<account>/melhoresdoano.app (ID na sidebar)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Vercel: token + project id (e team id se for um team account)
#   Pegar em: https://vercel.com/account/tokens
#   Project id em: Project → Settings → General
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# --- Operacional: email transacional (Resend) ---
# Se vazio, signup pula envio de email de boas-vindas.
#
# Resend: API key + sender verificado (dominio precisa estar verificado
# com SPF/DKIM no Resend dashboard).
#   https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=Melhores do Ano <ola@melhoresdoano.app>
