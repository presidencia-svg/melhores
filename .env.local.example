# =============================================
# Melhores do Ano CDL Aracaju — variáveis de ambiente
# Copie este arquivo para .env.local e preencha.
# =============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- SPC Brasil ---
SPC_API_URL=https://api.spcbrasil.com.br/spcconsulta/recurso/consulta/padrao
SPC_API_URL_HOMOLOG=https://treinamento.spcbrasil.com.br/spcconsulta/recurso/consulta/padrao
SPC_USER=
SPC_PASSWORD=
SPC_AMBIENTE=homologacao
SPC_CODIGO_PRODUTO=11
SPC_MOCK=false
SPC_SAMPLE_RATE=0.5

# --- Z-API (WhatsApp) ---
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# --- Cloudflare Turnstile (anti-bot) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Admin (autenticação simples por senha) ---
ADMIN_PASSWORD=
JWT_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=https://cdlaju.com
HASH_SALT=
